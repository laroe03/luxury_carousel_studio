# Copy this file to .env.local and fill in your values

# Anthropic Claude API Key (required if using Anthropic provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (required if using ChatGPT provider)
OPENAI_API_KEY=your_openai_api_key_here

# Site password (for Netlify auth guard)
SITE_PASSWORD=your_chosen_password_here

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET=your_random_32plus_char_string_here
